# =============================================================================
# MCP Zileo PDF - Configuration
# Copier ce fichier vers .env et remplir les valeurs
# =============================================================================

# === Application ===
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Mistral API (REQUIS) ===
MISTRAL_API_KEY=your_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_EMBED_MODEL=mistral-embed

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pdf_documents
# QDRANT_API_KEY=  # Optionnel, pour Qdrant Cloud

# === Processing ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50
OCR_DPI=300
OCR_MAX_CONCURRENT=5
OCR_TABLE_FORMAT=markdown

# === Limits ===
MAX_PDF_SIZE_MB=50
MAX_PDF_PAGES=1000
