# =============================================================================
# MCP Zileo RAG - Configuration
# Copier ce fichier vers .env et remplir les valeurs
# =============================================================================

# === Application ===
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Mistral API (REQUIS) ===
MISTRAL_API_KEY=your_api_key_here
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_EMBED_MODEL=mistral-embed

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents
# QDRANT_API_KEY=  # Optionnel, pour Qdrant Cloud

# === Processing ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50
OCR_DPI=300
OCR_MAX_CONCURRENT=5
OCR_TABLE_FORMAT=markdown

# === Paths ===
# Chemin vers le dossier contenant vos documents (PDF/Excel/Word)
# Monte en lecture seule dans le container
DOCUMENTS_PATH=/home/user/Documents
# Chemin vers le dossier de sortie des fichiers generes (Excel, etc.)
OUTPUT_PATH=/home/user/Documents/output

# === Limits ===
MAX_FILE_SIZE_MB=50
MAX_PAGES=1000
MAX_OUTPUT_FILE_SIZE_MB=10

# === Authentication ===
# Cle API pour proteger les endpoints (REQUIS hors mode DEBUG)
# Vide = pas d'auth (refuse au demarrage si DEBUG=false)
API_KEY=

# === Rate Limiting ===
# Format: "X/minute" ou "X/hour"
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_INDEX=10/minute
RATE_LIMIT_MCP=30/minute
RATE_LIMIT_SEARCH=30/minute
